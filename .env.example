# ---- clock & schedule ----
TZ=Europe/Rome           # local clock the anchors are pinned to
ANCHOR=06:20             # first window of the day (HH:MM, local)
WINDOWS=4                # number of windows from the anchor -> 06:20 / 11:20 / 16:20 / 21:20
WINDOW_HOURS=5           # length of the usage window being anchored

# ---- the ping ----
MODEL=claude-haiku-4-5-20251001   # cheapest model that still moves the window
PING_PROMPT=hi
MAX_TOKENS=1                       # keep the reply to a single token

# ---- confirmation / retry tuning ----
FRESH_TOLERANCE_MIN=10    # reset must be >= WINDOW_HOURS - this to count as a fresh window
RETRY_INTERVAL_SEC=120    # base wait between retries at a window edge / on transient error
RESET_BUFFER_SEC=45       # extra slack waited past a still-active window's reset
MAX_RETRIES=10            # safety cap on attempts per anchor
MAX_BACKOFF_SEC=1800      # cap on the exponential backoff applied to failed pings

# ---- plumbing (rarely changed) ----
# CLAUDE_DIR=/Users/you/.claude   # host dir mounted to /root/.claude (defaults to $HOME/.claude)
# OAUTH_BASE=https://platform.claude.com           # OAuth token endpoint host
# RESET_HEADER=anthropic-ratelimit-unified-reset   # set DEBUG=1 once to find the right header name
# DEBUG=0
